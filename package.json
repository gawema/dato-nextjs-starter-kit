{
  "name": "nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && prettier --check .",
    "generate-schema": "dotenv -c -- bash -c 'gql.tada generate schema https://graphql.datocms.com --header \"X-Exclude-Invalid: true\" --header \"Authorization: $DATOCMS_PUBLISHED_CONTENT_CDA_TOKEN\"'",
    "generate-cma-types": "dotenv -c -- bash -c 'datocms schema:generate src/lib/datocms/cma-types.ts --api-token $DATOCMS_CMA_TOKEN'",
    "format": "npx prettier . --write",
    "prepare": "npx simple-git-hooks && npm run generate-schema && npm run generate-cma-types"
  },
  "dependencies": {
    "@datocms/cda-client": "^0.2.10",
    "@datocms/cma-client": "^5.2.6",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@types/highlight.js": "^10.1.0",
    "classnames": "^2.5.1",
    "datocms-structured-text-to-plain-text": "^5.1.7",
    "datocms-structured-text-utils": "^5.1.7",
    "gql.tada": "^1.9.0",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "html-react-parser": "^6.0.0",
    "next": "^16",
    "node-html-parser": "^7.0.1",
    "react": "^19",
    "react-datocms": "^7.2.14",
    "react-dom": "^19",
    "react-icons": "^5.6.0",
    "serialize-error": "^12.0.0",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@datocms/cli": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "prettier": "3.7.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format"
  }
}
